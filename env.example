# TAKNET-PS AIS Aggregator — copy to .env and adjust
# install.sh sets INSTALL_DIR=/opt/taknet-ais-aggregator on the host

INSTALL_DIR=/opt/taknet-ais-aggregator

TZ=America/Los_Angeles
SITE_NAME=TAKNET-PS AIS Aggregator
# Dashboard listens here (Flask/Gunicorn)
WEB_PORT=5000

# Ingress — feeders connect here with NMEA/AIVDM (TCP)
AIS_FEEDER_PORT=10110

# ais-proxy → ais-core (internal)
AIS_CORE_HOST=ais-core
AIS_CORE_PORT=4000

# NetBird — feeder IP classification and hostnames
NETBIRD_ENABLED=true
NETBIRD_API_URL=https://netbird.yourdomain.com
NETBIRD_API_TOKEN=
NETBIRD_CIDR=100.64.0.0/10

GEOIP_ENABLED=true

# Dashboard (Flask) — full parity with TAKNET-PS Aggregator web app
SECRET_KEY=change-me
GITHUB_REPO=cfd2474/TAKNET-PS_AIS_AGGREGATOR
VESSELS_JSON_URL=http://ais-core:4001/data/vessels.json

# Resend (optional) — registration alerts, password reset, approval welcome
# INSTALL_DIR/.env can override; in Compose mount host .env if needed
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@notify.tak-solutions.com
RESEND_ADMIN_EMAILS=
