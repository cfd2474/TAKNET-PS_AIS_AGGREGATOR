# TAKNET-PS AIS Aggregator v0.2.0 — copy to .env and adjust
# install.sh sets INSTALL_DIR on the host. Must be an absolute path: docker-compose and
# Config → Updates (docker:cli) bind-mount this path on the Docker host — never use /app.

INSTALL_DIR=/opt/taknet-ais-aggregator

TZ=America/Los_Angeles
SITE_NAME=TAKNET-PS AIS Aggregator
# Default map center (/map)
SITE_LAT=33.8753
SITE_LON=-117.5664
# Dashboard listens here (Flask/Gunicorn)
WEB_PORT=5000

# Ingress — feeders connect here with NMEA/AIVDM (TCP)
AIS_FEEDER_PORT=10110

# ais-proxy → ais-core (internal)
AIS_CORE_HOST=ais-core
AIS_CORE_PORT=4000

# Optional: ais-proxy — forward !AIVDM/!AIVDO lines to UDP (e.g. AIS Friends welcome-email port)
# AIS_UDP_FORWARD_ENABLED=false
# AIS_UDP_FORWARD_TARGETS=ais.aisfriends.com:11884
# AIS_UDP_FORWARD_DNS_TTL_S=300

# NetBird — feeder IP classification and hostnames
NETBIRD_ENABLED=true
NETBIRD_API_URL=https://netbird.yourdomain.com
NETBIRD_API_TOKEN=
NETBIRD_CIDR=100.64.0.0/10

GEOIP_ENABLED=true

# Dashboard (Flask) — full parity with TAKNET-PS Aggregator web app
SECRET_KEY=change-me
GITHUB_REPO=cfd2474/TAKNET-PS_AIS_AGGREGATOR
# Combined map + dashboard: merged ais-core + AISstream (vessel-merger). Set to ais-core URL only to skip AISstream.
VESSELS_JSON_URL=http://vessel-merger:4003/data/vessels.json
# Feeder-only JSON for Direct map (ais-core HTTP)
DIRECT_VESSELS_JSON_URL=http://ais-core:4001/data/vessels.json

# Network feeds (optional) — AISstream, AIShub, aiscatcher.org, AIS Friends API v1; see Config → Services
NETWORK_FEED_OUTBOUND_ENABLED=false
NETWORK_FEED_INBOUND_ENABLED=false
# AISstream.io — https://aisstream.io/documentation (WebSocket; subscription needs BoundingBoxes)
# AISSTREAM_API_KEY=
# Optional JSON: [[[lat1,lon1],[lat2,lon2]], ...] — if unset, ±AISSTREAM_BBOX_SPAN_DEG around SITE_LAT/LON
# AISSTREAM_BOUNDING_BOXES=
# AISSTREAM_BBOX_SPAN_DEG=6
# AISHUB_POLL_URL=
# aiscatcher.org exchange (same names as docker-shipfeeder; https://www.aiscatcher.org/ )
# AISCATCHER_SHAREDATA=false
# AISCATCHER_FEEDER_KEY=
# AISCATCHER_SHAREKEY=

# AIS Friends — UDP upload (registration email: UDP to ais.aisfriends.com on assigned port, e.g. 11884)
# Built-in: set AIS_UDP_FORWARD_ENABLED=true and AIS_UDP_FORWARD_TARGETS=ais.aisfriends.com:PORT (ais-proxy).
# Alternative: docker-shipfeeder AISFRIENDS_UDP_PORT=11884 or ais.aisfriends.com:11884
# See https://github.com/sdr-enthusiasts/docker-shipfeeder#feeding-ais-aggregator-services
#
# AIS Friends API v1 (bidirectional HTTP — optional; dashboard Services) — https://www.aisfriends.com/docs/api/v1
# AISFRIENDS_API_V1_ENABLED=false
# AISFRIENDS_API_KEY=
# AISFRIENDS_API_BASE_URL=
# AISFRIENDS_STATION_ID=

# Resend (optional) — registration alerts, password reset, approval welcome
# INSTALL_DIR/.env can override; in Compose mount host .env if needed
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@notify.tak-solutions.com
RESEND_ADMIN_EMAILS=
